{
  "name": "fyp",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "dev:email": "email dev --dir ./src/modules/resend/emails",
    "build": "medusa build && pnpm run patch-admin && node src/scripts/postBuild.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "cd .medusa/server && medusa db:migrate && medusa start --verbose",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "patch-admin": "node node_modules/@techlabi/medusa-marketplace-plugin/.medusa/server/src/patch-admin.js",
    "postinstall": ""
  },
  "dependencies": {
    "@lambdacurry/medusa-product-reviews": "^1.3.1",
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/dashboard": "2.13.5",
    "@medusajs/draft-order": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/medusa": "2.13.5",
    "@react-email/components": "1.0.7",
    "@react-email/render": "^2.0.4",
    "@techlabi/medusa-marketplace-plugin": "^0.50.0",
    "minio": "^8.0.7",
    "ulid": "^2.4.0",
    "resend": "^6.9.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.5",
    "@react-email/preview-server": "^5.2.7",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "pnpm": {
    "overrides": {
      "@mikro-orm/core": "6.4.16",
      "@mikro-orm/knex": "6.4.16",
      "@mikro-orm/migrations": "6.4.16",
      "@mikro-orm/postgresql": "6.4.16"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
